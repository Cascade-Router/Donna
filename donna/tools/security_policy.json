{
  "version": 2,
  "description": "Declarative import tiers for Tool Forge AST gatekeeping.",
  "tier1_allowed": [
    "math",
    "json",
    "datetime",
    "re",
    "typing",
    "collections",
    "dataclasses",
    "decimal",
    "fractions",
    "statistics",
    "string",
    "textwrap",
    "itertools",
    "functools",
    "operator",
    "abc",
    "enum",
    "numbers",
    "copy",
    "hashlib",
    "base64",
    "uuid",
    "random",
    "time",
    "calendar"
  ],
  "tier2_review": [
    "pathlib",
    "tempfile",
    "io",
    "struct",
    "array",
    "csv",
    "html",
    "xml",
    "PIL",
    "Pillow",
    "psutil"
  ],
  "tier3_forbidden": [
    "os",
    "sys",
    "subprocess",
    "shutil",
    "socket",
    "ctypes",
    "multiprocessing",
    "importlib",
    "builtins",
    "pickle",
    "marshal",
    "pty",
    "fcntl",
    "signal",
    "threading",
    "http",
    "urllib",
    "requests",
    "winreg",
    "msvcrt",
    "code",
    "codeop",
    "ptyprocess",
    "asyncio",
    "concurrent",
    "inspect",
    "gc",
    "resource",
    "pwd",
    "grp"
  ],
  "forbidden_builtins": [
    "eval",
    "exec",
    "compile",
    "__import__",
    "open",
    "input",
    "breakpoint",
    "memoryview",
    "globals",
    "locals",
    "vars",
    "getattr",
    "setattr",
    "delattr"
  ],
  "allowed_from_modules": [
    "donna.tools.sandbox_io",
    "langchain_core.tools"
  ],
  "safe_path_resolvers": [
    "sandbox_read",
    "resolve_safe_path",
    "resolve_sandbox_path"
  ],
  "path_dependent_open_attrs": [
    "open"
  ],
  "notes": "File I/O must use sandbox_read() from donna.tools.sandbox_io — never native open(). Image loaders such as PIL.Image.open(...) are permitted ONLY when the path argument is produced by a safe resolver (resolve_safe_path / sandbox_read), e.g. Image.open(resolve_safe_path(filepath))."
}
